@page "/"
@rendermode InteractiveServer
@using BlazorGrid.Demo.ViewModels

<h1>BlazorGrid Demo</h1>

<BlazorGrid.Components.BlazorGrid Items="@employees"
                                  T="EmployeeViewModel"
                                  Title="Employee List"
                                  OnSortChanged="HandleSort" />

<p>Sort: @_sortInfo</p>

@code {
    private string _sortInfo = "No sort applied";

    private List<EmployeeViewModel> employees = new()
    {
        new() { Name = "Sadia Chowdhury",  Department = "Technology", Email = "sadia@example.com",  InternalCode = "EMP001" },
        new() { Name = "Rahel Ahmed",      Department = "Finance",    Email = "rahel@example.com",  InternalCode = "EMP002" },
        new() { Name = "Fatema Begum",     Department = "HR",         Email = "fatema@example.com", InternalCode = "EMP003" },
        new() { Name = "Karim Hassan",     Department = "Technology", Email = "karim@example.com",  InternalCode = "EMP004" },
    };

    private void HandleSort(SortState sort)
    {
        _sortInfo = $"Sorting by {sort.ColumnName} - {sort.Direction}";
    }
}