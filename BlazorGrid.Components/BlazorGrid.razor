@using BlazorGrid.Core
@typeparam T where T : class
<div class="mb-2 d-flex flex-wrap gap-3">
    @foreach (var column in _columns)
    {
        <div class="form-check">
            <input class="form-check-input"
                   type="checkbox"
                   checked="@column.IsVisible"
                   @onchange="() => ToggleColumn(column)"
                   id="col_@column.PropertyName" />
            <label class="form-check-label" for="col_@column.PropertyName">
                @column.DisplayName
            </label>
        </div>
    }
</div>
@if (!string.IsNullOrEmpty(Title))
{
    <h5 class="mb-3">@Title</h5>
}

<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                @foreach (var column in _columns)
                {
                    if (column.IsVisible)
                    {
                        <th @onclick="() => HandleSort(column)"
                            style="cursor:pointer; user-select:none;">
                            @column.DisplayName
                            @if (_sortState.ColumnName == column.PropertyName)
                            {
                                @(_sortState.Direction == SortDirection.Ascending ? " ▲" : " ▼")
                            }
                        </th>
                    }
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Items)
            {
                <tr>
                    @foreach (var column in _columns)
                    {
                        if (column.IsVisible)
                        {
                            <td>@GetValue(item, column.PropertyName)</td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
    @if (Pagination != null)
    {
        <div class="d-flex justify-content-between align-items-center mt-2">
            <small class="text-muted">
                Showing page @Pagination.PageNumber of @Pagination.TotalPages
                (@Pagination.TotalCount total records)
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(!Pagination.HasPreviousPage ? "disabled" : "")">
                        <button class="page-link"
                                @onclick="() => GoToPage(Pagination.PageNumber - 1)">
                            &laquo;
                        </button>
                    </li>
                    @for (int i = 1; i <= Pagination.TotalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(Pagination.PageNumber == pageNum ? "active" : "")">
                            <button class="page-link"
                                    @onclick="() => GoToPage(pageNum)">
                                @pageNum
                            </button>
                        </li>
                    }
                    <li class="page-item @(!Pagination.HasNextPage ? "disabled" : "")">
                        <button class="page-link"
                                @onclick="() => GoToPage(Pagination.PageNumber + 1)">
                            &raquo;
                        </button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
@code {
    [Parameter]
    public string Title { get; set; } = "";
    [Parameter]
    public EventCallback<SortState> OnSortChanged { get; set; }
    private SortState _sortState = new();
    [Parameter]
    public List<T> Items { get; set; } = new();
    private List<ColumnDefinition> _columns = new();
    [Parameter]
    public PaginationState? Pagination { get; set; }

    [Parameter]
    public EventCallback<PaginationState> OnPageChanged { get; set; }
    protected override void OnParametersSet()
    {
        if (Items != null && Items.Any())
        {
            var itemType = Items.First().GetType();
            var resolver = new ColumnResolver();
            _columns = resolver.ResolveByType(itemType);
        }
    }

    private string GetValue(T item, string propertyName)
    {
        if (item == null) return "";

        var value = typeof(T)
                .GetProperty(propertyName)
                ?.GetValue(item);

        return value?.ToString() ?? "";
    }
    private void ToggleColumn(ColumnDefinition column)
    {
        column.IsVisible = !column.IsVisible;
    }
    private async Task HandleSort(ColumnDefinition column)
    {
        if (!column.IsSortable)
            return;

        if (_sortState.ColumnName == column.PropertyName)
        {
            // same column clicked — flip direction
            _sortState.Direction = _sortState.Direction == SortDirection.Ascending
                ? SortDirection.Descending
                : SortDirection.Ascending;
        }
        else
        {
            // new column clicked — reset to ascending
            _sortState.ColumnName = column.PropertyName;
            _sortState.Direction = SortDirection.Ascending;
        }

        await OnSortChanged.InvokeAsync(_sortState);
    }
    private async Task GoToPage(int pageNumber)
    {
        if (Pagination == null) return;
        Pagination.PageNumber = pageNumber;
        await OnPageChanged.InvokeAsync(Pagination);
    }
}